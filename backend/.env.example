# KenduriLuhh Backend — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env

AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-kenduri
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_MAPS_KEY=your-azure-maps-primary-key-here
# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session config
SESSION_TTL_SECONDS=3600
MAX_PAX=5000

# Azure Maps — get Primary Key from Azure Portal → Maps Account → Authentication
# Client ID is already hardcoded (bbb5fdab-c8cb-4d2f-8f3f-9ddc3500a030)
AZURE_MAPS_KEY=your-azure-maps-primary-key-here
